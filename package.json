{
  "name": "doc.linea",
  "version": "3.3.1",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generateSocialCard.js && node scripts/updateCategories.js",
    "build": "docusaurus build",
    "postbuild": "node scripts/agent-docs/generate.js",
    "clean-slate": "bash ./clean-slate.sh",
    "clear": "docusaurus clear",
    "deploy": "docusaurus deploy",
    "docusaurus": "docusaurus",
    "format": "prettier --write \"{blog,docs,src,static}/(**/*).{md,mdx,ts,js,tsx,jsx,json}\"",
    "lint": "npm run lint:js && npm run lint:style",
    "lint:js": "eslint .",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:style": "stylelint \"**/*.css\"",
    "lint:style:fix": "npm run lint:style -- --fix",
    "agent-docs:test": "node --test scripts/agent-docs/*.test.js",
    "agent-docs:check": "node scripts/agent-docs/check.js",
    "serve": "docusaurus serve",
    "start": "docusaurus start",
    "swizzle": "docusaurus swizzle",
    "typecheck": "tsc",
    "typecheck-staged": "tsc-files --noEmit",
    "write-heading-ids": "docusaurus write-heading-ids",
    "write-translations": "docusaurus write-translations"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,js,jsx,tsx}": "npm run lint:js:fix",
    "**/*.{ts,tsx}": "npm run typecheck-staged",
    "**/*.css": "npm run lint:style",
    "**/*.{md,mdx,ts,js,tsx,jsx,json}": "npm run format"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "last 2 versions",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/plugin-client-redirects": "3.10.1",
    "@docusaurus/plugin-content-docs": "3.10.1",
    "@docusaurus/plugin-google-gtag": "3.10.1",
    "@docusaurus/plugin-google-tag-manager": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/remark-plugin-npm2yarn": "^3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "0.55.1",
    "@mdx-js/react": "3.1.1",
    "@mermaid-js/layout-elk": "0.1.9",
    "axios": "1.16.0",
    "browserslist": "4.28.2",
    "cheerio": "1.1.2",
    "clsx": "2.1.1",
    "concurrently": "9.2.1",
    "dompurify": "3.4.2",
    "dotenv": "17.4.2",
    "fast-xml-parser": "5.7.1",
    "gray-matter": "4.0.3",
    "hast-util-is-element": "3.0.0",
    "ignore": "7.0.5",
    "postcss-safe-parser": "7.0.1",
    "prism-react-renderer": "2.4.1",
    "raw-loader": "4.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-player": "3.4.0",
    "redocusaurus": "2.5.0",
    "sharp": "0.34.5",
    "turndown": "7.2.0",
    "turndown-plugin-gfm": "1.0.2",
    "yaml": "2.8.4"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@googleapis/sheets": "^13.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/node": "5.7.16",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.6.0",
    "google-auth-library": "^10.6.2",
    "googleapis-common": "^8.0.1",
    "lint-staged": "17.0.3",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "tsc-files": "1.1.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "engines": {
    "node": "24.14.1"
  },
  "overrides": {
    "@vercel/node": {
      "path-to-regexp": "6.3.0",
      "undici": "5.29.0"
    },
    "@vercel/static-config": {
      "ajv": "8.20.0"
    },
    "@vercel/python-analysis": {
      "minimatch": "10.2.5",
      "smol-toml": "1.6.1"
    },
    "fast-xml-parser": "5.7.1",
    "follow-redirects": "1.16.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "mermaid": "11.14.0",
    "serialize-javascript": "7.0.5"
  }
}
